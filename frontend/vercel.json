{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://portafolio-production-6311.up.railway.app/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build -- --configuration=production",
  "outputDirectory": "dist/inventario-pyme/browser",
  "framework": "angular"
}
