# Configuración del servidor
PORT=3000
NODE_ENV=development

# Seguridad JWT — reemplaza con una clave larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_aleatoria
JWT_EXPIRES_IN=24h

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=inventory_db

# CORS — origen permitido en producción
CORS_ORIGIN=http://localhost:4200
