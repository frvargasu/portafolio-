# =====================================================
# CONFIGURACIÓN DEL SISTEMA - INVENTARIO PYME
# =====================================================
# Copiar este archivo como .env y configurar los valores

# -----------------------------------------------------
# BASE DE DATOS
# -----------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventario_pyme
DB_USER=tu_usuario
DB_PASSWORD=tu_password_seguro
DB_ROOT_PASSWORD=root_password_seguro

# -----------------------------------------------------
# SERVIDOR
# -----------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------
# JWT (Autenticación)
# -----------------------------------------------------
# IMPORTANTE: Cambiar en producción por una clave segura de al menos 32 caracteres
JWT_SECRET=cambiar-por-clave-segura-en-produccion-min-32-chars
JWT_EXPIRES_IN=24h

# -----------------------------------------------------
# CORS
# -----------------------------------------------------
# En producción, especificar el dominio exacto del frontend
CORS_ORIGIN=http://localhost:4200

# -----------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# -----------------------------------------------------
# EMAIL (Recuperación de contraseña)
# -----------------------------------------------------
# Usar una App Password de Gmail (no la contraseña normal)
# Guia: https://support.google.com/accounts/answer/185833
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# URL del frontend (para el enlace en el email)
FRONTEND_URL=http://localhost:4200
